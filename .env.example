# ============================================================
#  Ron Bot — configuration minimale
#  Le bot est un pur relais Discord piloté par le site web.
#  Toute la logique métier, les schedulers et la config palier/podium
#  vivent côté ron-oil-web.
# ============================================================

# ── Discord ──
DISCORD_TOKEN=
# Optionnel : si vide, le bot utilise la première guild dont il est membre.
GUILD_ID=

# ── Serveur HTTP interne (appelé par ron-oil-web) ──
API_PORT=3001
# Doit correspondre à BOT_API_SECRET dans le .env du site web.
API_SECRET=

# ── Création des casiers (POST /casier) ──
EMPLOYEE_CATEGORY_ID=
EMPLOYEE_ROLE_ID=
VISITOR_ROLE_ID=
# URL envoyée dans le message de bienvenue d'un nouveau casier.
PANEL_URL=http://localhost:3000/

# ── Alertes contrats (POST /notify/contract-alert) ──
SECURITY_CHANNEL_ID=

# ── Embeds hebdo (POST /notify/weekly-stats) ──
# Symbole affiché dans les embeds ($ / € / £...).
CURRENCY_SYMBOL=$
